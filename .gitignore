# ==========================================
# Godot 4 Engine Caches and Temporary Files
# ==========================================
# The .godot folder contains imported assets and engine cache. 
# It is auto-generated by the engine and MUST NOT be tracked.
.godot/

# ==========================================
# Godot 3 Legacy (Optional safety)
# ==========================================
.import/
export_presets.cfg

# ==========================================
# Compiled Builds and Exported Binaries
# ==========================================
# Exclude compiled game versions to avoid bloating the repository
/builds/
/exports/
/bin/
*.exe
*.pck
*.apk
*.ipa
*.dmg
*.zip

# ==========================================
# OS Specific Junk Files
# ==========================================
# macOS thumbnail and directory cache
.DS_Store
.AppleDouble
.LSOverride

# Windows thumbnail and directory cache
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini

# ==========================================
# IDE and Editor Configuration Files
# ==========================================
# VSCode
.vscode/

# Visual Studio
.vs/
*.suo
*.user